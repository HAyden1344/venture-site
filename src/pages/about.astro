---
import "../styles/global.css";
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>About Venture</title>
    </head>

    <body>
        <section class="about">
            <!-- Decorative circles -->
            <div class="about-circle about-circle-1"></div>
            <div class="about-circle about-circle-2"></div>

            <div class="about-inner">
                <div class="about-header">
                    <span class="about-tag">What's the deal?</span>

                    <h2>
                        Games Meet the<br>
                        <span>Great Outdoors</span>
                    </h2>

                    <p class="about-description">
                        Venture is Vancouver's first outdoor themed game jam — a three day
                        creative marathon where game developers build something beautiful,
                        surrounded by nature's finest inspiration.
                    </p>
                </div>

                <div class="about-grid">
                    <div class="about-card">
                        <div class="about-icon"></div>
                        <h3>LaSalle College Campus</h3>
                        <p>
                            Hack at LaSalle College's Vancouver campus — creative studios,
                            open labs, and outdoor courtyards surrounded by the city's lush greenery.
                        </p>
                    </div>

                    <div class="about-card">
                        <div class="about-icon"></div>
                        <h3>12-Hour Sprint to Steam</h3>
                        <p>
                            From Friday evening kickoff to Saturday morning. Polish, build,
                            and ship your game live to Steam before the clock runs out.
                        </p>
                    </div>

                    <div class="about-card">
                        <div class="about-icon"></div>
                        <h3>Hack Club Creators</h3>
                        <p>
                            Solo devs, artists, musicians, and storytellers come together.
                            Find your dream team or design your game solo.
                        </p>
                    </div>

                    <div class="about-card">
                        <div class="about-icon"></div>
                        <h3>Tall Timber Dorms</h3>
                        <p>
                            Sleep steps away from the action at BCIT's Tall Timber residence.
                            With lounges made for development, it is cozy, convenient, and part of the full Venture experience.
                        </p>
                    </div>
                </div>
            </div>
        </section>

