---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Venture</title>
  </head>

  <body class="home">

    <!-- Hero / Header -->
    <section class="hero">
      <div class="hero-content">

        <div class="date-badge">
          <span>September 25–28, 2026 • Vancouver, BC</span>
        </div>

        <h1><span>VENTURE</span></h1>

        <p>
          Build your game. Ship to Steam. Show the world.
        </p>

        <div class="hero-buttons">
          <a href="/join" class="btn-primary">Register Now</a>
          <a href="/about" class="btn-outline">Learn More</a>
        </div>

      </div>

    <!-- Floating shapes -->
      <div class="shape-circle"></div>
      <div class="shape-small"></div>
      <div class="shape-diamond"></div>
    </section>

    <!-- Footer -->
    <footer>
      <p>© 2026 Venture</p>
	  <p>Fiscally sponsored by the Hack Club Foundation</p>
    </footer>
  </body>
</html>